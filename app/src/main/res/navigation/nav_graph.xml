<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.c25kv2.FirstFragment"
        android:label="Run"
        tools:layout="@layout/fragment_first">

        <action
            android:id="@+id/action_FirstFragment_to_WorkoutFragment"
            app:destination="@id/WorkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/StatsFragment"
        android:name="com.example.c25kv2.StatsFragment"
        android:label="Stats"
        tools:layout="@layout/fragment_stats" />

    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.example.c25kv2.SecondFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_second" />

    <fragment
        android:id="@+id/WorkoutFragment"
        android:name="com.example.c25kv2.WorkoutFragment"
        android:label="Workout"
        tools:layout="@layout/fragment_workout">
        <argument
            android:name="workoutTitle"
            app:argType="string" />
    </fragment>
</navigation>